{
  "manifest_version": 3,
  "name": "Price Hunter — Compare prices instantly",
  "short_name": "Price Hunter",
  "description": "Compare prices across 14 MENA stores while you shop. Set alerts. Find coupons.",
  "version": "1.0.0",
  "default_locale": "en",
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "https://www.amazon.sa/*",
    "https://www.amazon.eg/*",
    "https://www.amazon.ae/*",
    "https://www.noon.com/*",
    "https://www.jarir.com/*",
    "https://www.extra.com/*",
    "https://www.jumia.com.eg/*",
    "https://www.btech.com/*",
    "https://www.2b.com.eg/*",
    "https://www.sharafdg.com/*",
    "https://www.carrefouruae.com/*",
    "https://www.luluhypermarket.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.sa/*/dp/*",
        "https://www.amazon.eg/*/dp/*",
        "https://www.amazon.ae/*/dp/*"
      ],
      "js": ["content-scripts/amazon.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://www.noon.com/*/p/*"
      ],
      "js": ["content-scripts/noon.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
