# ============================================
# Price Hunter - Docker Ignore
# Files excluded from Docker build context
# ============================================

# Dependencies
node_modules
npm-debug.log
yarn-error.log

# Next.js build output
.next
out
build

# Testing
coverage
.nyc_output
playwright-report
test-results

# Environment files (SECURITY)
.env
.env.*
!.env.example

# IDE and Editor
.idea
.vscode
*.swp
*.swo
*.sublime-*
.editorconfig

# OS files
.DS_Store
Thumbs.db
*.log

# Documentation (keep README for reference)
*.md
!README.md
docs

# Git
.git
.gitignore
.gitattributes

# Docker files (don't need inside container)
Dockerfile*
docker-compose*
.dockerignore

# Tests (not needed in production)
tests
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
playwright.config.ts
vitest.config.ts
jest.config.*

# Config files not needed in production
.eslintrc*
eslint.config.*
.prettierrc*
tsconfig.test.json

# Local development
.turbo
*.local

# Nginx config (mounted separately)
nginx

# Scripts (except production scripts)
scripts/*.sh
!scripts/start.sh
!scripts/init-db.sql

# Temporary files
tmp
temp
*.tmp
*.temp

# Cache directories
.cache
.npm
.pnpm-store
